# Normalize line endings: store text as LF in the repo and check out LF on all
# platforms. This ends the "LF will be replaced by CRLF" warnings on Windows
# (git autocrlf) and keeps diffs clean across contributors.
* text=auto eol=lf

# Explicitly binary — never touch these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
